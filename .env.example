# Sécurité
JWT_SECRET=changez-moi-en-production

# URL du frontend (liens « Rejoindre la coopérative », sans slash final)
# En production, utiliser : https://agrixlogix.vercel.app
APP_PUBLIC_WEB_URL=http://localhost:5173

# Origins autorisées pour les appels API depuis ton site (liste séparée par virgules, sans slash final)
# Exemple : https://mondomaine.vercel.app,https://www.mondomaine.com
CORS_ORIGINS=

# Pour autoriser automatiquement les sous-domaines de preview *.vercel.app (moins restrictif — dev/preview uniquement recommandé)
# CORS_ALLOW_VERCEL_PREVIEW=1

# Blockchain (optionnel) — désactiver tout : BLOCKCHAIN_DISABLED=1
# Copiez config/blockchain-addresses.example.json vers blockchain-addresses.local.json et renseignez les adresses du déployement Hardhat.
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_ARTIFACTS_DIR=C:/chemin/vers/cooledger-contracts/artifacts
BLOCKCHAIN_ADDRESSES_FILE=config/blockchain-addresses.local.json
# Libellé affiché sur le tableau de bord (/stats → blockchain.status)
BLOCKCHAIN_NETWORK_LABEL=Hardhat local

# Ou adresses JSON brutes au lieu du fichier :
# BLOCKCHAIN_ADDRESSES_JSON={"CoopLedger":"0x...", "Vote":"0x...", "Cooperative":"0x...", "Portefeuille":"0x...", "MobileMoney":"0x..."}
